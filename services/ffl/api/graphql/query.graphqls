type Query {
  fflClubs: [FFLClub!]!
  fflClub(id: ID!): FFLClub!
  fflPlayers: [FFLPlayer!]!
  fflPlayer(id: ID!): FFLPlayer!
  fflSeasons: [FFLSeason!]!
  fflSeason(id: ID!): FFLSeason!
  fflClubSeason(seasonId: ID!, clubId: ID!): FFLClubSeason
  fflRoundByAflRound(aflRoundId: ID!): FFLRound
  fflRound(id: ID!): FFLRound
  fflMatch(id: ID!): FFLMatch
}

type FFLClub {
  id: ID!
  name: String!
}

type FFLPlayer {
  id: ID!
  name: String!
  aflPlayerId: ID!
}

type FFLSeason {
  id: ID!
  name: String!
  ladder: [FFLClubSeason!]!
  rounds: [FFLRound!]!
}

type FFLRound {
  id: ID!
  name: String!
  aflRoundId: ID
  season: FFLSeason!
  matches: [FFLMatch!]!
}

type FFLMatch {
  id: ID!
  venue: String
  startTime: String
  result: String
  round: FFLRound!
  homeClubMatch: FFLClubMatch
  awayClubMatch: FFLClubMatch
}

type FFLClubMatch {
  id: ID!
  club: FFLClub!
  score: Int!
  playerMatches: [FFLPlayerMatch!]!
}

type FFLClubSeason {
  id: ID!
  club: FFLClub!
  season: FFLSeason!
  played: Int!
  won: Int!
  lost: Int!
  drawn: Int!
  for: Int!
  against: Int!
  percentage: Float!
  players(first: Int, after: String, filter: FFLPlayerSeasonFilter): FFLPlayerSeasonConnection!
}

type FFLPlayerSeason {
  id: ID!
  player: FFLPlayer!
  clubSeasonId: ID!
  aflPlayerSeasonId: ID
}

type FFLPlayerSeasonConnection {
  nodes: [FFLPlayerSeason!]!
  pageInfo: PageInfo!
  totalCount: Int!
}

input FFLPlayerSeasonFilter {
  active: Boolean
}

type FFLPlayerMatch {
  id: ID!
  playerSeasonId: ID!
  player: FFLPlayer!
  position: String
  status: String
  backupPositions: String
  interchangePosition: String
  score: Int!
}

# --- Data ops types ---

input ParseTeamSubmissionInput {
  clubSeasonId: ID!
  clubMatchId: ID!
  teamName: String!
  post: String!
}

type ParseTeamSubmissionResult {
  resolvedPlayers: [ResolvedPlayer!]!
  needsReview: [Int!]!
}

type ResolvedPlayer {
  parsedName: String!
  clubHint: String!
  resolvedName: String
  resolvedClub: String
  position: String!
  backupPositions: String!
  interchangePosition: String!
  score: Int
  notes: String!
  playerSeasonId: ID
  confidence: Float!
}

input ConfirmTeamSubmissionInput {
  clubMatchId: ID!
  players: [ConfirmedPlayerInput!]!
}

input ConfirmedPlayerInput {
  playerSeasonId: ID!
  position: String!
  backupPositions: String
  interchangePosition: String
  score: Int
}
